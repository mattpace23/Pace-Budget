{
  "name": "pace-budget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev -- npm run dev",
    "db:migrate:local": "wrangler d1 migrations apply pace-budget --local",
    "db:migrate:remote": "wrangler d1 migrations apply pace-budget --remote",
    "db:console:local": "wrangler d1 execute pace-budget --local --command",
    "db:console:remote": "wrangler d1 execute pace-budget --remote --command"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^4.95.0"
  }
}
